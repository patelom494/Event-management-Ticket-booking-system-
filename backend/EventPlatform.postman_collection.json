            "body": { "mode": "formdata", "formdata": [{ "key": "category_id", "value": "CATEGORY_ID_HERE", "type": "text" }, { "key": "event_name", "value": "Arijit Singh Live Concert", "type": "text" }, { "key": "artist_name", "value": "Arijit Singh", "type": "text" }, { "key": "price_per_seat", "value": "1500", "type": "text" }, { "key": "total_seats", "value": "500", "type": "text" }, { "key": "address", "value": "GMDC Ground, Ahmedabad, Gujarat", "type": "text" }, { "key": "lattitute", "value": "23.0562", "type": "text" }, { "key": "longitude", "value": "72.5922", "type": "text" }, { "key": "datetime", "value": "2025-12-20T19:00:00", "type": "text" }, { "key": "event_img", "src": "", "type": "file" }, { "key": "artist_image", "src": "", "type": "file" }] }
          }
        },
        {
          "name": "Update Event (with images)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/admin/updateEvent", "host": ["{{base_url}}"], "path": ["admin", "updateEvent"] },
            "body": { "mode": "formdata", "formdata": [{ "key": "id", "value": "EVENT_ID_HERE", "type": "text" }, { "key": "event_name", "value": "Arijit Singh Grand Concert", "type": "text" }, { "key": "price_per_seat", "value": "1800", "type": "text" }, { "key": "status", "value": "Active", "type": "text" }, { "key": "event_img", "src": "", "type": "file" }, { "key": "artist_image", "src": "", "type": "file" }] }
          }
        },
        {
          "name": "Delete Event",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/deleteEvent/EVENT_ID_HERE", "host": ["{{base_url}}"], "path": ["admin", "deleteEvent", "EVENT_ID_HERE"] } }
