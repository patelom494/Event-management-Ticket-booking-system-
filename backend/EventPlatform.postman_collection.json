          "request": { "method": "POST", "url": { "raw": "{{base_url}}/admin/resolveComplaint/COMPLAINT_ID_HERE", "host": ["{{base_url}}"], "path": ["admin", "resolveComplaint", "COMPLAINT_ID_HERE"] } }
