            "body": { "mode": "formdata", "formdata": [{ "key": "name", "value": "Singing", "type": "text" }, { "key": "image", "src": "", "type": "file" }] }
          }
        },
        {
          "name": "Update Category (with image)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/admin/updateCategory", "host": ["{{base_url}}"], "path": ["admin", "updateCategory"] },
            "body": { "mode": "formdata", "formdata": [{ "key": "id", "value": "CATEGORY_ID_HERE", "type": "text" }, { "key": "name", "value": "Live Singing", "type": "text" }, { "key": "image", "src": "", "type": "file" }] }
          }
        },
        {
          "name": "Delete Category",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/deleteCategory/CATEGORY_ID_HERE", "host": ["{{base_url}}"], "path": ["admin", "deleteCategory", "CATEGORY_ID_HERE"] } }
